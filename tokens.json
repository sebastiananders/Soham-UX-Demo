{
  "$metadata": {
    "name": "Soham UX Demo",
    "description": "Semantic design token set extracted from styles/theme.css and app/App.tsx. Format: W3C Design Token Community Group (DTCG).",
    "version": "1.0.0"
  },

  "color": {
    "primitive": {
      "$description": "Raw color values — the source of truth referenced by semantic tokens.",
      "white":        { "$type": "color", "$value": "#ffffff" },
      "black":        { "$type": "color", "$value": "#000000" },
      "brand-yellow": { "$type": "color", "$value": "#FFF000", "$description": "Soham brand accent — submit button" },
      "near-black":   { "$type": "color", "$value": "#030213", "$description": "Primary UI tone" },
      "neutral": {
        "50":  { "$type": "color", "$value": "#fafafa" },
        "100": { "$type": "color", "$value": "#f5f5f5" },
        "200": { "$type": "color", "$value": "#e5e5e5" },
        "300": { "$type": "color", "$value": "#d4d4d4" },
        "400": { "$type": "color", "$value": "#a3a3a3" },
        "500": { "$type": "color", "$value": "#737373" },
        "600": { "$type": "color", "$value": "#525252" },
        "700": { "$type": "color", "$value": "#404040" },
        "800": { "$type": "color", "$value": "#262626" },
        "900": { "$type": "color", "$value": "#171717" }
      },
      "blue": {
        "100": { "$type": "color", "$value": "#dbeafe" },
        "600": { "$type": "color", "$value": "#2563eb" }
      },
      "emerald": {
        "500": { "$type": "color", "$value": "#10b981" }
      },
      "orange": {
        "500": { "$type": "color", "$value": "#f97316" }
      },
      "red": {
        "500": { "$type": "color", "$value": "#ef4444" }
      }
    },

    "semantic": {
      "$description": "Purpose-based tokens that map onto primitives. Swap these for dark mode.",
      "background":             { "$type": "color", "$value": "#ffffff",               "$description": "Page / surface background" },
      "foreground":             { "$type": "color", "$value": "oklch(0.145 0 0)",      "$description": "Default body text" },
      "primary":                { "$type": "color", "$value": "#030213",               "$description": "Primary interactive elements" },
      "primary-foreground":     { "$type": "color", "$value": "#ffffff" },
      "secondary":              { "$type": "color", "$value": "oklch(0.95 0.0058 264.53)" },
      "secondary-foreground":   { "$type": "color", "$value": "#030213" },
      "muted":                  { "$type": "color", "$value": "#ececf0",               "$description": "Muted backgrounds (pills, input bg)" },
      "muted-foreground":       { "$type": "color", "$value": "#717182",               "$description": "Placeholder, secondary label text" },
      "accent":                 { "$type": "color", "$value": "#e9ebef" },
      "accent-foreground":      { "$type": "color", "$value": "#030213" },
      "destructive":            { "$type": "color", "$value": "#d4183d" },
      "destructive-foreground": { "$type": "color", "$value": "#ffffff" },
      "border":                 { "$type": "color", "$value": "rgba(0,0,0,0.1)",       "$description": "Default border color" },
      "border-subtle":          { "$type": "color", "$value": "#f5f5f5",               "$description": "Barely-there border — card edges" },
      "input":                  { "$type": "color", "$value": "transparent" },
      "input-background":       { "$type": "color", "$value": "#f3f3f5" },
      "switch-background":      { "$type": "color", "$value": "#cbced4" },
      "ring":                   { "$type": "color", "$value": "oklch(0.708 0 0)",      "$description": "Focus ring" }
    },

    "component": {
      "sidebar": {
        "surface":            { "$type": "color", "$value": "oklch(0.985 0 0)",    "$description": "Sidebar background" },
        "foreground":         { "$type": "color", "$value": "oklch(0.145 0 0)" },
        "primary":            { "$type": "color", "$value": "#030213" },
        "primary-foreground": { "$type": "color", "$value": "oklch(0.985 0 0)" },
        "accent":             { "$type": "color", "$value": "oklch(0.97 0 0)",     "$description": "Hovered nav item background" },
        "accent-foreground":  { "$type": "color", "$value": "oklch(0.205 0 0)" },
        "border":             { "$type": "color", "$value": "oklch(0.922 0 0)" },
        "ring":               { "$type": "color", "$value": "oklch(0.708 0 0)" },
        "active-bg":          { "$type": "color", "$value": "#fafafa",             "$description": "Active nav item — neutral-50" },
        "active-text":        { "$type": "color", "$value": "#171717",             "$description": "Active nav item label — neutral-900" },
        "icon":               { "$type": "color", "$value": "#a3a3a3",             "$description": "Nav icon default — neutral-400" }
      },
      "card": {
        "surface":    { "$type": "color", "$value": "#ffffff" },
        "foreground": { "$type": "color", "$value": "oklch(0.145 0 0)" },
        "border":     { "$type": "color", "$value": "#f5f5f5",  "$description": "Subtle card border — neutral-100" }
      },
      "notification": {
        "badge-background": { "$type": "color", "$value": "#dbeafe",   "$description": "blue-100" },
        "badge-foreground": { "$type": "color", "$value": "#2563eb",   "$description": "blue-600" }
      },
      "status": {
        "success": { "$type": "color", "$value": "#10b981", "$description": "emerald-500 — registrations, insights tag" },
        "warning": { "$type": "color", "$value": "#f97316", "$description": "orange-500 — event website tag" },
        "danger":  { "$type": "color", "$value": "#ef4444", "$description": "red-500 — deadline alert" }
      },
      "input-bar": {
        "background":    { "$type": "color", "$value": "#ffffff" },
        "placeholder":   { "$type": "color", "$value": "#a3a3a3", "$description": "neutral-400" },
        "text":          { "$type": "color", "$value": "#171717", "$description": "neutral-900 — typed value" },
        "icon":          { "$type": "color", "$value": "#a3a3a3", "$description": "neutral-400" },
        "icon-hover":    { "$type": "color", "$value": "#525252", "$description": "neutral-600" },
        "icon-button-bg":{ "$type": "color", "$value": "#f5f5f5", "$description": "neutral-100 — plus icon circle" }
      },
      "submit-button": {
        "background": { "$type": "color", "$value": "#FFF000", "$description": "Brand yellow — appears when input has text" },
        "foreground": { "$type": "color", "$value": "#171717", "$description": "neutral-900" }
      },
      "suggestion-pill": {
        "background":       { "$type": "color", "$value": "#fafafa",   "$description": "neutral-50" },
        "background-hover": { "$type": "color", "$value": "#ffffff" },
        "foreground":       { "$type": "color", "$value": "#404040",   "$description": "neutral-700" }
      },
      "popover": {
        "surface":    { "$type": "color", "$value": "oklch(1 0 0)" },
        "foreground": { "$type": "color", "$value": "oklch(0.145 0 0)" }
      }
    },

    "chart": {
      "$description": "Data visualisation palette.",
      "1": { "$type": "color", "$value": "oklch(0.646 0.222 41.116)" },
      "2": { "$type": "color", "$value": "oklch(0.6 0.118 184.704)" },
      "3": { "$type": "color", "$value": "oklch(0.398 0.07 227.392)" },
      "4": { "$type": "color", "$value": "oklch(0.828 0.189 84.429)" },
      "5": { "$type": "color", "$value": "oklch(0.769 0.188 70.08)" }
    }
  },

  "typography": {
    "fontFamily": {
      "sans":    { "$type": "fontFamily", "$value": ["ui-sans-serif", "system-ui", "sans-serif"],   "$description": "Body / UI text — font-sans" },
      "serif":   { "$type": "fontFamily", "$value": ["ui-serif", "Georgia", "serif"],               "$description": "Display headings — font-serif (Aloha, Jen)" },
      "mono":    { "$type": "fontFamily", "$value": ["ui-monospace", "SFMono-Regular", "monospace"],"$description": "Code" }
    },
    "fontSize": {
      "xs":      { "$type": "dimension", "$value": "10px",  "$description": "Notification badge count" },
      "sm-card": { "$type": "dimension", "$value": "12px",  "$description": "Card body, card tag labels" },
      "sm":      { "$type": "dimension", "$value": "14px",  "$description": "Nav labels, status text, pill text — text-sm" },
      "base":    { "$type": "dimension", "$value": "16px",  "$description": "Input value / placeholder, base font-size" },
      "display": { "$type": "dimension", "$value": "33px",  "$description": "\"Aloha, Jen\" greeting heading" }
    },
    "fontWeight": {
      "normal":   { "$type": "fontWeight", "$value": 400, "$description": "Body text, pills" },
      "medium":   { "$type": "fontWeight", "$value": 500, "$description": "Notification label, UI labels" },
      "semibold": { "$type": "fontWeight", "$value": 600, "$description": "Active nav item, card titles" },
      "bold":     { "$type": "fontWeight", "$value": 700, "$description": "Card category tags" }
    },
    "lineHeight": {
      "tight":  { "$type": "number", "$value": 1.25, "$description": "Card title headings — leading-tight" },
      "normal": { "$type": "number", "$value": 1.5,  "$description": "Body text, labels — leading-[1.5]" }
    }
  },

  "spacing": {
    "scale": {
      "$description": "Tailwind-compatible 4px grid. Multiply index by 4px.",
      "1":   { "$type": "dimension", "$value": "4px" },
      "1-5": { "$type": "dimension", "$value": "6px" },
      "2":   { "$type": "dimension", "$value": "8px" },
      "3":   { "$type": "dimension", "$value": "12px" },
      "4":   { "$type": "dimension", "$value": "16px" },
      "5":   { "$type": "dimension", "$value": "20px" },
      "6":   { "$type": "dimension", "$value": "24px" },
      "8":   { "$type": "dimension", "$value": "32px" },
      "12":  { "$type": "dimension", "$value": "48px" },
      "20":  { "$type": "dimension", "$value": "80px" }
    },
    "component": {
      "sidebar-width-collapsed": { "$type": "dimension", "$value": "64px",  "$description": "Sidebar — icon-only state" },
      "sidebar-width-expanded":  { "$type": "dimension", "$value": "200px", "$description": "Sidebar — label-visible state" },
      "sidebar-padding-y":       { "$type": "dimension", "$value": "32px",  "$description": "py-8" },
      "sidebar-nav-padding-x":   { "$type": "dimension", "$value": "8px",   "$description": "px-2" },
      "sidebar-item-padding":    { "$type": "dimension", "$value": "12px",  "$description": "px-3 py-3" },
      "logo-width":              { "$type": "dimension", "$value": "45px" },
      "logo-height":             { "$type": "dimension", "$value": "36px" },
      "logo-margin-bottom":      { "$type": "dimension", "$value": "48px",  "$description": "mb-12" },
      "content-max-width":       { "$type": "dimension", "$value": "820px", "$description": "max-w-[820px] — hero and cards container" },
      "hero-padding-top":        { "$type": "dimension", "$value": "200px", "$description": "pt-[200px]" },
      "hero-gap":                { "$type": "dimension", "$value": "30px",  "$description": "gap-[30px]" },
      "input-bar-width":         { "$type": "dimension", "$value": "600px" },
      "input-bar-height":        { "$type": "dimension", "$value": "57px" },
      "input-bar-padding-x":     { "$type": "dimension", "$value": "20px" },
      "card-width":              { "$type": "dimension", "$value": "254px" },
      "card-padding":            { "$type": "dimension", "$value": "27px" },
      "card-gap":                { "$type": "dimension", "$value": "14px",  "$description": "gap-[14px] — between card header and body" },
      "cards-top-margin":        { "$type": "dimension", "$value": "120px", "$description": "mt-[120px]" },
      "avatar-size":             { "$type": "dimension", "$value": "40px",  "$description": "w-10 h-10" },
      "icon-xs":                 { "$type": "dimension", "$value": "14px",  "$description": "w-3.5 h-3.5" },
      "icon-sm":                 { "$type": "dimension", "$value": "16px",  "$description": "w-4 h-4" },
      "icon-md":                 { "$type": "dimension", "$value": "20px",  "$description": "w-5 h-5" },
      "icon-button-size":        { "$type": "dimension", "$value": "24px",  "$description": "w-6 h-6 — plus icon circle" },
      "submit-button-size":      { "$type": "dimension", "$value": "57px",  "$description": "Yellow arrow button — same height as input bar" }
    }
  },

  "borderRadius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "sm":   { "$type": "dimension", "$value": "6px",     "$description": "calc(--radius - 4px) — nav items, small elements" },
    "md":   { "$type": "dimension", "$value": "8px",     "$description": "calc(--radius - 2px)" },
    "lg":   { "$type": "dimension", "$value": "10px",    "$description": "--radius — base radius" },
    "xl":   { "$type": "dimension", "$value": "14px",    "$description": "calc(--radius + 4px) — cards, background panels" },
    "pill": { "$type": "dimension", "$value": "28.5px",  "$description": "Input bar rounded pill shape" },
    "full": { "$type": "dimension", "$value": "9999px",  "$description": "Fully circular — pills, avatar, badges, submit button" }
  },

  "shadow": {
    "sm":         { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "2px",  "spread": "0px", "color": "rgba(0,0,0,0.05)" },                   "$description": "Tailwind shadow-sm — avatar" },
    "card":       { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "9px",  "spread": "0px", "color": "rgba(0,0,0,0.05)" },                   "$description": "Default card shadow" },
    "card-hover": { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "4px", "blur": "16px", "spread": "0px", "color": "rgba(0,0,0,0.10)" },                   "$description": "Card shadow on hover" },
    "input":      { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "2px", "blur": "8px",  "spread": "0px", "color": "rgba(23,23,23,0.10)" },                "$description": "Main prompt input bar shadow" },
    "toggle":     { "$type": "shadow", "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "3px",  "spread": "0px", "color": "rgba(0,0,0,0.08)" },                   "$description": "Sidebar collapse toggle button" }
  },

  "transition": {
    "duration": {
      "fast":   { "$type": "duration", "$value": "150ms", "$description": "Shadow transitions, opacity fades" },
      "base":   { "$type": "duration", "$value": "200ms", "$description": "Sidebar expand, text fade, color transitions" },
      "slow":   { "$type": "duration", "$value": "350ms", "$description": "Pill collapse animation (max-width)" }
    },
    "easing": {
      "default": { "$type": "cubicBezier", "$value": [0.25, 0.1, 0.25, 1], "$description": "CSS ease — used for all transitions" }
    }
  },

  "zIndex": {
    "behind":  { "$type": "number", "$value": -10, "$description": "Illustration, decorative backgrounds" },
    "content": { "$type": "number", "$value": 10,  "$description": "Hero section, cards" },
    "overlay": { "$type": "number", "$value": 20,  "$description": "Sidebar, notification header" },
    "floating":{ "$type": "number", "$value": 30,  "$description": "Sidebar toggle button" }
  }
}
